{
  "name": "finledger-api",
  "version": "1.0.0",
  "description": "Role-gated financial records and analytics REST API",
  "main": "src/server.js",
  "scripts": {
    "start": "node --experimental-sqlite src/server.js",
    "dev": "nodemon --exec 'node --experimental-sqlite' src/server.js",
    "seed": "node --experimental-sqlite scripts/seed.js",
    "test": "node --experimental-sqlite node_modules/jest/bin/jest.js --forceExit --runInBand"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",

    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.18.3",
    "express-rate-limit": "^7.2.0",
    "express-validator": "^7.0.1",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.0",
    "uuid": "^9.0.1"
  },
  "devDependencies": {
    "jest": "^29.7.0",
    "nodemon": "^3.1.0",
    "supertest": "^7.1.3"
  }
}
